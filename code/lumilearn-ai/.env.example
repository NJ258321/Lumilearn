# =====================================================
# 前端环境变量配置模板
# 复制此文件为 .env.local 并填写实际值
# =====================================================

# Gemini API Key（用于AI功能）
GEMINI_API_KEY=your_gemini_api_key_here

# API 基础地址（后端服务器地址）
# 开发环境使用 localhost
VITE_API_BASE_URL=http://localhost:3000

# 生产环境示例：
# VITE_API_BASE_URL=https://your-api-domain.com
